# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get from: https://console.neon.tech → Connection Details
# Use the "pooled" connection string for the app (Prisma at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth.js v5 ───────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
AUTH_SECRET="your-random-32-char-secret-here"
# Base URL (set to Vercel URL in production)
NEXTAUTH_URL="http://localhost:3000"

# ─── OAuth Providers (optional, add as needed) ────────────────────────────────
# Google OAuth — https://console.cloud.google.com
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
